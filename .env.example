# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# OpenAI Model (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Twilio credentials for WhatsApp (optional)
TWILIO_ACCOUNT_SID=AC...
# Auth Token de la cuenta (dashboard Account), no el "API Key Secret"
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Opcional: origen público del webhook (sin path), si la firma sigue fallando
TWILIO_WEBHOOK_BASE_URL=

# Application settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Admin authentication (required for catalog import)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET_KEY=change-this-secret-key-in-production

# Catalog upload settings
CATALOG_UPLOAD_DIR=uploads
CATALOG_MAX_FILE_SIZE_MB=50
CATALOG_ALLOWED_EXTENSIONS=.pdf
